// ============================================
// Shopping Service - Business Logic for Shopping Items
// ============================================

import { ShoppingItem } from '@/types';
import { generateId, getData, saveData, STORAGE_KEYS } from '@/utils/storage';

class ShoppingService {
  // ============================================
  // GET ALL SHOPPING ITEMS
  // ============================================
  async getShoppingItems(profileID: string): Promise<ShoppingItem[]> {
    try {
      const items = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS);
      if (!items) return [];
      return items.filter(item => item.profileID === profileID);
    } catch (error) {
      console.error('Error getting shopping items:', error);
      return [];
    }
  }

  // ============================================
  // ADD MONTHLY ESSENTIAL (from class diagram)
  // ============================================
  async addMonthlyEssential(
    itemData: Omit<ShoppingItem, 'id' | 'createdAt' | 'updatedAt' | 'type' | 'isBought'>
  ): Promise<ShoppingItem> {
    try {
      const newItem: ShoppingItem = {
        ...itemData,
        id: generateId(),
        type: 'monthly',
        isBought: false,
        createdAt: new Date(),
        updatedAt: new Date(),
      };

      const existingItems = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS) || [];
      const updatedItems = [...existingItems, newItem];
      await saveData(STORAGE_KEYS.SHOPPING_ITEMS, updatedItems);

      return newItem;
    } catch (error) {
      console.error('Error adding monthly essential:', error);
      throw error;
    }
  }

  // ============================================
  // ADD SHOPPING ITEM (General)
  // ============================================
  async addShoppingItem(
    itemData: Omit<ShoppingItem, 'id' | 'createdAt' | 'updatedAt' | 'isBought'>
  ): Promise<ShoppingItem> {
    try {
      const newItem: ShoppingItem = {
        ...itemData,
        id: generateId(),
        isBought: false,
        createdAt: new Date(),
        updatedAt: new Date(),
      };

      const existingItems = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS) || [];
      const updatedItems = [...existingItems, newItem];
      await saveData(STORAGE_KEYS.SHOPPING_ITEMS, updatedItems);

      return newItem;
    } catch (error) {
      console.error('Error adding shopping item:', error);
      throw error;
    }
  }

  // ============================================
  // EDIT SHOPPING ITEM
  // ============================================
  async editShoppingItem(
    itemId: string,
    updates: Partial<ShoppingItem>
  ): Promise<ShoppingItem | null> {
    try {
      const items = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS) || [];
      const index = items.findIndex(item => item.id === itemId);

      if (index === -1) {
        throw new Error('Shopping item not found');
      }

      const updatedItem: ShoppingItem = {
        ...items[index],
        ...updates,
        updatedAt: new Date(),
      };

      items[index] = updatedItem;
      await saveData(STORAGE_KEYS.SHOPPING_ITEMS, items);

      return updatedItem;
    } catch (error) {
      console.error('Error editing shopping item:', error);
      return null;
    }
  }

  // ============================================
  // DELETE SHOPPING ITEM
  // ============================================
  async deleteShoppingItem(itemId: string): Promise<boolean> {
    try {
      const items = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS) || [];
      const filteredItems = items.filter(item => item.id !== itemId);
      await saveData(STORAGE_KEYS.SHOPPING_ITEMS, filteredItems);
      return true;
    } catch (error) {
      console.error('Error deleting shopping item:', error);
      return false;
    }
  }

  // ============================================
  // MARK ITEM AS BOUGHT (from class diagram)
  // ============================================
  async markItemAsBought(itemId: string, isBought: boolean): Promise<boolean> {
    try {
      const items = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS) || [];
      const item = items.find(i => i.id === itemId);

      if (!item) return false;

      item.isBought = isBought;
      item.boughtAt = isBought ? new Date() : undefined;
      item.updatedAt = new Date();

      await saveData(STORAGE_KEYS.SHOPPING_ITEMS, items);
      return true;
    } catch (error) {
      console.error('Error marking item as bought:', error);
      return false;
    }
  }

  // ============================================
  // VIEW HISTORY (from class diagram)
  // ============================================
  async viewHistory(profileID: string): Promise<ShoppingItem[]> {
    try {
      const items = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS);
      if (!items) return [];
      
      // Return bought items, sorted by boughtAt date
      return items
        .filter(item => item.profileID === profileID && item.isBought)
        .sort((a, b) => {
          if (!a.boughtAt || !b.boughtAt) return 0;
          return new Date(b.boughtAt).getTime() - new Date(a.boughtAt).getTime();
        });
    } catch (error) {
      console.error('Error getting shopping history:', error);
      return [];
    }
  }

  // ============================================
  // SHARE SHOPPING LIST (from class diagram)
  // ============================================
  async shareShoppingList(itemId: string, shareWithFamily: boolean): Promise<boolean> {
    try {
      const items = await getData<ShoppingItem[]>(STORAGE_KEYS.SHOPPING_ITEMS) || [];
      const item = items.find(i => i.id === itemId);

      if (!item) return false;

      item.isShared = shareWithFamily;
      item.updatedAt = new Date();

      await saveData(STORAGE_KEYS.SHOPPING_ITEMS, items);
      return true;
    } catch (error) {
      console.error('Error sharing shopping list:', error);
      return false;
    }
  }

  // ============================================
  // GET MONTHLY ITEMS
  // ============================================
  async getMonthlyItems(profileID: string): Promise<ShoppingItem[]> {
    try {
      const items = await this.getShoppingItems(profileID);
      return items.filter(item => item.type === 'monthly');
    } catch (error) {
      console.error('Error getting monthly items:', error);
      return [];
    }
  }

  // ============================================
  // GET URGENT ITEMS
  // ============================================
  async getUrgentItems(profileID: string): Promise<ShoppingItem[]> {
    try {
      const items = await this.getShoppingItems(profileID);
      return items.filter(item => item.type === 'urgent');
    } catch (error) {
      console.error('Error getting urgent items:', error);
      return [];
    }
  }

  // ============================================
  // GET PENDING ITEMS (Not Bought)
  // ============================================
  async getPendingItems(profileID: string): Promise<ShoppingItem[]> {
    try {
      const items = await this.getShoppingItems(profileID);
      return items.filter(item => !item.isBought);
    } catch (error) {
      console.error('Error getting pending items:', error);
      return [];
    }
  }

  // ============================================
  // BACKEND INTEGRATION NOTES:
  // ============================================
  // When backend is ready, replace with:
  // - GET /api/shopping/:profileId
  // - POST /api/shopping
  // - PUT /api/shopping/:id
  // - DELETE /api/shopping/:id
  // - PATCH /api/shopping/:id/bought
  // - PATCH /api/shopping/:id/share
}

export default new ShoppingService();
