// ============================================
// Profile Service - Mock Data & Business Logic
// Will be replaced with API calls when backend is ready
// ============================================

import { Profile } from '@/types';
import { generateId, getData, saveData, STORAGE_KEYS } from '@/utils/storage';

class ProfileService {
  // ============================================
  // GET PROFILE
  // ============================================
  async getProfile(): Promise<Profile | null> {
    try {
      return await getData<Profile>(STORAGE_KEYS.PROFILE);
    } catch (error) {
      console.error('Error getting profile:', error);
      return null;
    }
  }

  // ============================================
  // ADD PROFILE
  // ============================================
  async addProfile(profileData: Omit<Profile, 'id' | 'createdAt' | 'updatedAt'>): Promise<Profile> {
    try {
      const newProfile: Profile = {
        ...profileData,
        id: generateId(),
        createdAt: new Date(),
        updatedAt: new Date(),
      };

      await saveData(STORAGE_KEYS.PROFILE, newProfile);
      return newProfile;
    } catch (error) {
      console.error('Error adding profile:', error);
      throw error;
    }
  }

  // ============================================
  // EDIT PROFILE
  // ============================================
  async editProfile(profileData: Partial<Profile>): Promise<Profile | null> {
    try {
      const existingProfile = await this.getProfile();
      if (!existingProfile) {
        throw new Error('Profile not found');
      }

      const updatedProfile: Profile = {
        ...existingProfile,
        ...profileData,
        updatedAt: new Date(),
      };

      await saveData(STORAGE_KEYS.PROFILE, updatedProfile);
      return updatedProfile;
    } catch (error) {
      console.error('Error editing profile:', error);
      return null;
    }
  }

  // ============================================
  // VIEW PROFILE (same as get, but explicit for class diagram)
  // ============================================
  async viewProfile(): Promise<Profile | null> {
    return this.getProfile();
  }

  // ============================================
  // BACKEND INTEGRATION NOTES:
  // ============================================
  // When backend is ready, replace with:
  // - GET /api/profile/:id
  // - POST /api/profile
  // - PUT /api/profile/:id
  // Keep the same function signatures, just replace implementation
}

export default new ProfileService();
