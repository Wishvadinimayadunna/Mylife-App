// ============================================
// Future Event Service - Business Logic for Future Events
// ============================================

import { FutureEvent } from '@/types';
import { generateId, getData, saveData, STORAGE_KEYS } from '@/utils/storage';

class FutureEventService {
  // ============================================
  // GET ALL FUTURE EVENTS
  // ============================================
  async getFutureEvents(profileID: string): Promise<FutureEvent[]> {
    try {
      const events = await getData<FutureEvent[]>(STORAGE_KEYS.FUTURE_EVENTS);
      if (!events) return [];
      return events.filter(event => event.profileID === profileID);
    } catch (error) {
      console.error('Error getting future events:', error);
      return [];
    }
  }

  // ============================================
  // ADD EVENT (from class diagram)
  // ============================================
  async addEvent(
    eventData: Omit<FutureEvent, 'id' | 'createdAt' | 'updatedAt'>
  ): Promise<FutureEvent> {
    try {
      const newEvent: FutureEvent = {
        ...eventData,
        id: generateId(),
        createdAt: new Date(),
        updatedAt: new Date(),
      };

      const existingEvents = await getData<FutureEvent[]>(STORAGE_KEYS.FUTURE_EVENTS) || [];
      const updatedEvents = [...existingEvents, newEvent];
      await saveData(STORAGE_KEYS.FUTURE_EVENTS, updatedEvents);

      // Schedule reminders based on reminderOptions
      await this.scheduleReminders(newEvent);

      return newEvent;
    } catch (error) {
      console.error('Error adding event:', error);
      throw error;
    }
  }

  // ============================================
  // EDIT EVENT (from class diagram)
  // ============================================
  async editEvent(
    eventId: string,
    updates: Partial<FutureEvent>
  ): Promise<FutureEvent | null> {
    try {
      const events = await getData<FutureEvent[]>(STORAGE_KEYS.FUTURE_EVENTS) || [];
      const index = events.findIndex(event => event.id === eventId);

      if (index === -1) {
        throw new Error('Event not found');
      }

      const updatedEvent: FutureEvent = {
        ...events[index],
        ...updates,
        updatedAt: new Date(),
      };

      events[index] = updatedEvent;
      await saveData(STORAGE_KEYS.FUTURE_EVENTS, events);

      // Reschedule reminders if needed
      if (updates.reminderOptions || updates.eventDate) {
        await this.scheduleReminders(updatedEvent);
      }

      return updatedEvent;
    } catch (error) {
      console.error('Error editing event:', error);
      return null;
    }
  }

  // ============================================
  // DELETE EVENT (from class diagram)
  // ============================================
  async deleteEvent(eventId: string): Promise<boolean> {
    try {
      const events = await getData<FutureEvent[]>(STORAGE_KEYS.FUTURE_EVENTS) || [];
      const filteredEvents = events.filter(event => event.id !== eventId);
      await saveData(STORAGE_KEYS.FUTURE_EVENTS, filteredEvents);
      
      // Cancel scheduled notifications for this event
      // TODO: Implement notification cancellation
      
      return true;
    } catch (error) {
      console.error('Error deleting event:', error);
      return false;
    }
  }

  // ============================================
  // SHARE EVENT WITH FAMILY (from class diagram)
  // ============================================
  async shareEventWithFamily(eventId: string, shareWithFamily: boolean): Promise<boolean> {
    try {
      const events = await getData<FutureEvent[]>(STORAGE_KEYS.FUTURE_EVENTS) || [];
      const event = events.find(e => e.id === eventId);

      if (!event) return false;

      event.isShared = shareWithFamily;
      event.updatedAt = new Date();

      await saveData(STORAGE_KEYS.FUTURE_EVENTS, events);
      return true;
    } catch (error) {
      console.error('Error sharing event:', error);
      return false;
    }
  }

  // ============================================
  // RECEIVE EVENT NOTIFICATION (from class diagram)
  // ============================================
  async receiveEventNotification(eventId: string): Promise<FutureEvent | null> {
    try {
      const events = await getData<FutureEvent[]>(STORAGE_KEYS.FUTURE_EVENTS) || [];
      const event = events.find(e => e.id === eventId);
      
      if (!event) return null;
      
      // Mark notification as received/viewed
      // This could update a notification status or log
      return event;
    } catch (error) {
      console.error('Error receiving event notification:', error);
      return null;
    }
  }

  // ============================================
  // SCHEDULE REMINDERS
  // ============================================
  private async scheduleReminders(event: FutureEvent): Promise<void> {
    try {
      const eventDate = new Date(event.eventDate);
      
      for (const reminderOption of event.reminderOptions) {
        let reminderDate: Date;
        
        switch (reminderOption) {
          case '1_week_before':
            reminderDate = new Date(eventDate);
            reminderDate.setDate(reminderDate.getDate() - 7);
            break;
          case '1_day_before':
            reminderDate = new Date(eventDate);
            reminderDate.setDate(reminderDate.getDate() - 1);
            break;
          case 'same_day':
            reminderDate = new Date(eventDate);
            break;
          default:
            continue;
        }

        // TODO: Schedule actual notification using expo-notifications
        console.log(`Scheduled reminder for ${event.title} at ${reminderDate}`);
      }

      // If sendReminderToSpouse is true, also send to spouse
      if (event.sendReminderToSpouse) {
        console.log(`Will send reminder to spouse for ${event.title}`);
      }
    } catch (error) {
      console.error('Error scheduling reminders:', error);
    }
  }

  // ============================================
  // GET UPCOMING EVENTS
  // ============================================
  async getUpcomingEvents(profileID: string, daysAhead: number = 30): Promise<FutureEvent[]> {
    try {
      const events = await this.getFutureEvents(profileID);
      const now = new Date();
      const futureDate = new Date();
      futureDate.setDate(futureDate.getDate() + daysAhead);

      return events
        .filter(event => {
          const eventDate = new Date(event.eventDate);
          return eventDate >= now && eventDate <= futureDate && !event.completedAt;
        })
        .sort((a, b) => new Date(a.eventDate).getTime() - new Date(b.eventDate).getTime());
    } catch (error) {
      console.error('Error getting upcoming events:', error);
      return [];
    }
  }

  // ============================================
  // GET EVENTS BY TYPE
  // ============================================
  async getEventsByType(profileID: string, type: string): Promise<FutureEvent[]> {
    try {
      const events = await this.getFutureEvents(profileID);
      return events.filter(event => event.type === type);
    } catch (error) {
      console.error('Error getting events by type:', error);
      return [];
    }
  }

  // ============================================
  // MARK EVENT AS COMPLETED
  // ============================================
  async markEventCompleted(eventId: string): Promise<boolean> {
    try {
      const events = await getData<FutureEvent[]>(STORAGE_KEYS.FUTURE_EVENTS) || [];
      const event = events.find(e => e.id === eventId);

      if (!event) return false;

      event.completedAt = new Date();
      event.updatedAt = new Date();

      await saveData(STORAGE_KEYS.FUTURE_EVENTS, events);
      return true;
    } catch (error) {
      console.error('Error marking event completed:', error);
      return false;
    }
  }

  // ============================================
  // BACKEND INTEGRATION NOTES:
  // ============================================
  // When backend is ready, replace with:
  // - GET /api/events/:profileId
  // - POST /api/events
  // - PUT /api/events/:id
  // - DELETE /api/events/:id
  // - PATCH /api/events/:id/share
  // - PATCH /api/events/:id/complete
}

export default new FutureEventService();
